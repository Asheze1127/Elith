# Keep build contexts small and avoid leaking local artifacts/secrets.
.git
.gitignore
.dockerignore

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ruff_cache/

# Node / Next.js
node_modules/
.next/
npm-debug.log*

# Local env and secrets (never bake into images)
.env
*.env
!.env.example

# Editor / OS
.vscode/
.idea/
.DS_Store
