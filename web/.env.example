# Environment config (app-wide startup condition, not a per-tenant setting).
# Copy to .env.local and adjust. Base URL of the FastAPI backend (see
# docker-compose.yml's api service, port 8000).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Local-only tenant header fallback used by backend/app/deps/tenant.py.
NEXT_PUBLIC_LOCAL_TENANT_ID=1
