# Web image for the Next.js frontend.
# Build context is ./web (see docker-compose.yml), so paths below are relative
# to web/.
#
# Multi-stage build: `next build` needs devDependencies (typescript, eslint,
# vitest's types, etc.), but the final image should only ship prod deps. A
# single-stage build with NODE_ENV=production set before `npm ci` would make
# npm skip devDependencies (npm's `omit` config defaults to `dev` under
# NODE_ENV=production), causing `next build` to fail (or, worse, silently
# auto-install missing packages mid-build if the environment happens to have
# network access -- non-reproducible and broken in network-isolated CI).
FROM node:20-slim AS builder

WORKDIR /app

# Install ALL dependencies (including dev) for the build step.
COPY package.json package-lock.json ./
RUN npm ci

COPY . ./
RUN npm run build

FROM node:20-slim

ENV NODE_ENV=production

WORKDIR /app

# Separate, prod-only install for the runtime image.
COPY package.json package-lock.json ./
RUN npm ci --omit=dev

COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/next.config.ts ./next.config.ts

EXPOSE 3000

CMD ["npm", "start"]
